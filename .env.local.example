# このファイルは「環境変数のテンプレート（見本）」です。
# 実際に使うときは、このファイルを .env.local という名前でコピーし、各値を埋めてください。
#   cp .env.local.example .env.local
# .env.local は .gitignore で除外されており、Git にコミットされません。

# ----------------------------------------------------------------
# Firebase（クライアントで使うため NEXT_PUBLIC_ を付ける）
# Firebase コンソール > プロジェクトの設定 > マイアプリ から取得できます。
# ※ これらは「公開しても問題ない」設定値です（秘密鍵ではありません）。
# ----------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ----------------------------------------------------------------
# microCMS（サーバーサイド専用。絶対に NEXT_PUBLIC_ を付けないこと！）
# 付けるとブラウザに API キーが漏れ、誰でも管理 API を叩けてしまいます。
# ----------------------------------------------------------------
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=

# ----------------------------------------------------------------
# Firebase Admin SDK（サーバーサイド専用。秘密鍵なので絶対に NEXT_PUBLIC_ を付けないこと！）
# 署名（petitions）の集計・公開分の取得・作成をサーバー側で安全に行うために使います。
#
# 取得方法:
#   Firebase コンソール > プロジェクトの設定 > サービス アカウント >
#   「新しい秘密鍵の生成」で JSON をダウンロードし、その中の値を設定します。
#     - project_id     → FIREBASE_ADMIN_PROJECT_ID
#     - client_email   → FIREBASE_ADMIN_CLIENT_EMAIL
#     - private_key    → FIREBASE_ADMIN_PRIVATE_KEY
#
# ※ FIREBASE_ADMIN_PRIVATE_KEY は複数行のため、改行を \n に置き換えて
#    ダブルクォートで囲んだ1行で設定します（コード側で実際の改行へ戻します）。
#    例: FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# ----------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ----------------------------------------------------------------
# 管理者（運営者）のメールアドレス（サーバーサイド専用。NEXT_PUBLIC_ は付けないこと！）
# 署名の管理画面（/admin/petitions）を閲覧できる運営者を指定します。
# 複数登録する場合はカンマ区切りで並べます（前後の空白は無視されます）。
# ここに登録された Google アカウントのメールでログインした人だけが、
# サーバー側の判定（ID トークン検証 + 突き合わせ）を通過して署名一覧を閲覧できます。
#   例: ADMIN_EMAILS="admin1@example.com,admin2@example.com"
# ----------------------------------------------------------------
ADMIN_EMAILS=

# ----------------------------------------------------------------
# Stripe（寄付の決済に使用）
# テスト用キーは pk_test_… / sk_test_… で始まります。
# ----------------------------------------------------------------
# 公開キー。クライアント側で使うため NEXT_PUBLIC_ を付ける（公開されても問題ない値）。
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# シークレットキー。サーバー専用。絶対に NEXT_PUBLIC_ を付けず、クライアントに渡さないこと！
STRIPE_SECRET_KEY=
