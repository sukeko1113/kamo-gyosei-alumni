rules_version = '2';

// Cloud Firestore セキュリティルール。
//
// 基本方針: 「すべて拒否（deny-all）」を土台にし、必要な操作だけを
// コレクションごとに明示的に許可する。許可を書き忘れたものは届かない＝安全側に倒れる。
//
// ※ サーバー（Firebase Admin SDK / サービスアカウント）からのアクセスは
//    これらのルールをバイパスする。本サイトでは署名の読み取り・作成は
//    サーバー側（Admin SDK）で行うため、ここでのクライアント向けルールは
//    「万一クライアントから直接アクセスされた場合の保険（多層防御）」として機能する。
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------
    // 会員プロフィール: users コレクション（Phase 1）
    // ドキュメント ID は Firebase Authentication の uid。
    // ------------------------------------------------------------
    match /users/{userId} {

      // ログイン中の本人（uid とドキュメント ID が一致）かどうか。
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      // 読み取り・作成は本人のみ。
      allow read: if isOwner();
      allow create: if isOwner();

      // 更新は本人のみ。かつ role は変更不可（改ざん防止）。
      allow update: if isOwner() &&
                       request.resource.data.role == resource.data.role;

      // 削除はクライアントから不可。
      allow delete: if false;
    }

    // ------------------------------------------------------------
    // 署名（嘆願）: petitions コレクション
    // ------------------------------------------------------------
    match /petitions/{petitionId} {

      // 立場（role）として許可する値。空文字（未選択）も許可する。
      function isValidRole(role) {
        return role == '' ||
               role in ['卒業生', '保護者', '在校生', '教職員', '地域住民', 'その他'];
      }

      // 作成データのバリデーション。
      // - name / email は空でない文字列
      // - role は許可値のいずれか、または空文字
      // - isPublic は真偽値
      // - createdAt はサーバータイムスタンプ（= リクエスト時刻）であること
      // - 想定外のフィールドを含めない
      function isValidNewSignature() {
        let data = request.resource.data;
        return data.keys().hasOnly(['name', 'email', 'role', 'comment', 'isPublic', 'createdAt']) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.email is string && data.email.size() > 0 && data.email.size() <= 254 &&
               isValidRole(data.role) &&
               (!('comment' in data) || data.comment is string) &&
               data.isPublic is bool &&
               data.createdAt == request.time;
      }

      // 作成（create）は未ログインを含め誰でも可。ただし上記バリデーションを満たすこと。
      allow create: if isValidNewSignature();

      // 読み取り（read）はクライアントから一切不可。
      // email など個人情報を含むため、集計・公開分の取得はサーバー側のみで行う。
      allow read: if false;

      // 更新・削除はクライアントから不可。
      allow update, delete: if false;
    }

    // ------------------------------------------------------------
    // 上記以外はすべて拒否（deny-all）。
    // 新しいコレクションを許可する場合は、必ず個別の match で明示すること。
    // ------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
